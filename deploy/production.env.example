# Copy this file to a private production env file before running docker-compose.prod.yml.
# Do not commit real production secrets.

PUBLIC_APP_HOST=tasks.example.com
PUBLIC_APP_URL=https://tasks.example.com
TRUSTED_ORIGINS=https://tasks.example.com
VITE_API_BASE_URL=/api

POSTGRES_DB=team_task_tracker
POSTGRES_USER=team_task_tracker
POSTGRES_PASSWORD=replace-with-private-postgres-password
# The backend safely builds DATABASE_URL from these values when DATABASE_URL is unset.
# Set DATABASE_URL only when an explicit external PostgreSQL connection URL is required.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# Override these host ports when 80/443 are already in use during production-like QA.
PRODUCTION_HTTP_PORT=80
PRODUCTION_HTTPS_PORT=443

SESSION_TTL=168h
SESSION_COOKIE_SECURE=true
CSRF_SECRET=replace-with-private-32-character-csrf-secret
RATE_LIMIT_LOGIN_PER_MINUTE=10

APP_VERSION=production
BUILD_COMMIT=unknown
BUILD_TIME=

# V5 SMTP/email settings. Delivery is disabled until a real SMTP provider is configured.
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Kelmio
SMTP_TLS_MODE=starttls
EMAIL_WORKER_POLL_INTERVAL=10s
EMAIL_MAX_ATTEMPTS=5
PASSWORD_RESET_TTL=30m

# V5 metrics settings. Keep this token private; Prometheus will use it later.
METRICS_ENABLED=true
METRICS_AUTH_TOKEN=replace-with-private-32-character-metrics-token
EMAIL_WORKER_METRICS_PORT=9091

# Used only by the one-time bootstrap-admin tool. Replace every value before use.
# Remove BOOTSTRAP_ADMIN_PASSWORD from the private env file after bootstrap succeeds.
BOOTSTRAP_WORKSPACE_NAME=Production Workspace
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_USERNAME=production_admin
BOOTSTRAP_ADMIN_DISPLAY_NAME=Production Admin
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-bootstrap-admin-password
