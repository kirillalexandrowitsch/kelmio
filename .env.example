APP_ENV=development
BACKEND_PORT=8080
FRONTEND_PORT=5173
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

POSTGRES_DB=team_task_tracker
POSTGRES_USER=team_task_tracker
POSTGRES_PASSWORD=team_task_tracker
POSTGRES_PORT=15432

DATABASE_URL=postgres://team_task_tracker:team_task_tracker@localhost:15432/team_task_tracker?sslmode=disable
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8080

# V3 production config placeholders.
# For APP_ENV=production, set PUBLIC_APP_URL and TRUSTED_ORIGINS to your real HTTPS origin.
# Production must set SESSION_COOKIE_SECURE=true and replace CSRF_SECRET with a private 32+ character value.
PUBLIC_APP_URL=https://tasks.example.com
TRUSTED_ORIGINS=https://tasks.example.com
SESSION_TTL=168h
SESSION_COOKIE_SECURE=false
CSRF_SECRET=
RATE_LIMIT_LOGIN_PER_MINUTE=10
APP_VERSION=development
BUILD_COMMIT=local
BUILD_TIME=

# V5 local email config. Development Docker Compose sends mail to Mailpit.
# Leave SMTP_HOST empty for defaults: Docker Compose uses mailpit, local go run uses localhost.
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@team-task-tracker.local
SMTP_FROM_NAME=Team Task Tracker
SMTP_TLS_MODE=none
EMAIL_DELIVERY_ENABLED=true
EMAIL_WORKER_POLL_INTERVAL=10s
EMAIL_MAX_ATTEMPTS=5
PASSWORD_RESET_TTL=30m

# V5 local metrics config. Development allows /metrics without a token.
METRICS_ENABLED=true
METRICS_AUTH_TOKEN=
EMAIL_WORKER_METRICS_PORT=9091

SEED_WORKSPACE_NAME=Local Workspace
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Admin
SEED_DEMO_EMAIL=demo.member@example.com
SEED_DEMO_USERNAME=demo_member
SEED_DEMO_PASSWORD=demo12345
SEED_DEMO_NAME=Demo Member
